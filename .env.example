# ClawMem 配置文件

# 数据库配置
DATABASE_PATH=./clawmem.db
DATABASE_WAL_MODE=true

# L0/L1/L2 配置
L0_MAX_SUMMARY_LENGTH=100
L1_MAX_SUMMARY_LENGTH=500
L2_STORE_HIGH_VALUE_ONLY=true

# Token 估算 (1 token ≈ 4 chars)
TOKEN_ESTIMATE_RATIO=4

# 生命周期监听配置
LIFECYCLE_EVENTS=session.start,session.end,tool.call,memory.read,memory.write
WORKER_INTERVAL_MS=1000

# LLM 配置（用于语义摘要）
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=500

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/clawmem.log

# 性能配置
MAX_RETRIEVE_LIMIT=100
CACHE_ENABLED=true
CACHE_TTL_MS=300000
